{
  "name": "@playroom/db",
  "private": true,
  "version": "0.1.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "lint": "echo \"No package-specific lint configured for @playroom/db\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:check": "drizzle-kit up:pg",
    "db:push": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "tsx": "^4.20.3"
  },
  "dependencies": {
    "drizzle-orm": "^0.30.0",
    "drizzle-kit": "^0.20.0",
    "postgres": "^3.4.3"
  }
}
