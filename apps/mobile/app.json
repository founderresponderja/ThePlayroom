{
  "expo": {
    "name": "The Playroom",
    "slug": "the-playroom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "theplayroom",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0708"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pt.theplayroom.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0708"
      },
      "package": "pt.theplayroom.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
